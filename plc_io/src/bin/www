#!/usr/bin/env node
require('module-alias/register')
const path = require('path')
require('dotenv').config({ path: path.join(__dirname, '../../.env'), silent: true })
const app = require('@root/app')
const loop = require('@root/control')

const PORT = process.env.PORT_RW || 4001
const HOST = process.env.IP_RW || 'localhost'

start()
loop().then().catch(console.error)

process.on('SIGTERM', () => graceful('SIGTERM'))
process.on('SIGINT', () => graceful('SIGINT'))

async function start() {
	try {
		// Передаем объект с port и host
		await app.listen({ port: Number(PORT), host: HOST })
	} catch (error) {
		console.error('Ошибка при старте сервера:', error)
		process.exit(1)
	}
}

async function graceful(code) {
	console.log(`\nЗакрываем микросервис. Код ${code}`)
	try {
		// Закрываем все сетевые соединения
		await app.close()
		console.log('Микросервис успешно остановлен.')
		process.exit(0)
	} catch (err) {
		console.error('Ошибка при плавном закрытии:', err)
		process.exit(1)
	}
}
